<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp">

        <ImageView
            android:id="@+id/img_SanPham"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:scaleType="centerCrop"
            android:src="@drawable/bg_white_card"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_TenSanPham"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:text="Tên sản phẩm"
            android:textColor="@android:color/black"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/btn_Xoa"
            app:layout_constraintStart_toEndOf="@+id/img_SanPham"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_GiaSanPham"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="0.000 đ"
            android:textColor="@color/text_grey"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="@+id/tv_TenSanPham"
            app:layout_constraintTop_toBottomOf="@+id/tv_TenSanPham" />

        <ImageView
            android:id="@+id/btn_Xoa"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_delete"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/primary_red" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/btn_GiamSoLuong"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:background="@drawable/bg_input_field"
                android:padding="4dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="@color/text_grey" />

            <TextView
                android:id="@+id/tv_SoLuong"
                android:layout_width="40dp"
                android:layout_height="30dp"
                android:background="#33837F7F"
                android:gravity="center"
                android:text="1"
                android:textColor="@color/primary_red"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/btn_TangSoLuong"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:background="@drawable/bg_input_field"
                android:padding="4dp"
                android:src="@android:drawable/ic_input_add"
                app:tint="@color/text_grey" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>